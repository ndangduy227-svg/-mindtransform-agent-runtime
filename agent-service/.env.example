# ── agent-service environment ──────────────────────────────
# Copy to .env and fill. Founder must create accounts/keys (see v3 doc §8).

# HTTP
PORT=8080
ENGINE_API_KEY=
PUBLIC_APP_URL=http://localhost:3000

# Supabase (state, checkpoint, pg-boss queue, cost, leads)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=  # ưu tiên; nếu trống sẽ fallback ANON (writes bị RLS chặn)
SUPABASE_ANON_KEY=
# Direct Postgres connection string (pg-boss + LangGraph PostgresSaver)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Neo4j Aura (knowledge graph + native vector index)
# Lấy từ file credentials .txt tải về lúc tạo instance (KHÔNG phải file .backup)
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j       # Aura đôi khi dùng tên db = instance id

# Models (router cascade). Keep env names aligned with Next.js control plane.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Lark / Feishu bot app
LARK_APP_ID=
LARK_APP_SECRET=

# Safety brakes
MAX_ITERATIONS=3
COST_CAP_USD_DAILY=5
GRAPHRAG_MAX_HOPS=2

# Tenant (single-tenant now; Mind = tenant_0)
DEFAULT_TENANT_ID=tenant_0
